{
  "name": "flakyguard",
  "version": "1.0.0",
  "description": "GitHub Action to detect flaky tests in Java projects by running the test suite multiple times",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build index.js -o dist --license licenses.txt",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^6.0.0",
    "fast-xml-parser": "^4.4.1",
    "glob": "^10.4.5"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.2"
  },
  "license": "MIT",
  "keywords": [
    "github-action",
    "flaky-tests",
    "java",
    "maven",
    "junit",
    "testng",
    "test-stability"
  ]
}
